# Jira credentials — set these in Vercel dashboard under Project Settings → Environment Variables
# Never commit real values here

# Your Jira cloud ID
JIRA_CLOUD_ID=210f1844-2859-4e67-9d41-597bd3d1df7f

# Email of the service account used to generate the API token
JIRA_EMAIL=your-service-account@homethrive.com

# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
# Use a dedicated service account, not your personal account
JIRA_API_TOKEN=your-api-token-here
